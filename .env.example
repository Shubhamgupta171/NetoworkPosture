# ---- Backend ----
# Single API key shared by scanner ingestion and frontend reads.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=replace-me-with-a-strong-random-token

# Storage backend: "memory" (in-process), "file" (local JSON), or "dynamodb"
STORAGE_BACKEND=file
LOCAL_STORE_PATH=./data/store.json

# DynamoDB (only used when STORAGE_BACKEND=dynamodb)
AWS_REGION=ap-south-1
DYNAMODB_TABLE=network-posture-scanner

# CORS — comma-separated origins allowed to read the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# ---- Scanner ----
# Where to send results. For local dev this is the FastAPI server.
NPS_API_URL=http://localhost:8000
NPS_API_KEY=replace-me-with-a-strong-random-token

# ---- Frontend ----
# Vite reads VITE_*-prefixed vars at build time.
VITE_API_URL=http://localhost:8000
VITE_API_KEY=replace-me-with-a-strong-random-token
